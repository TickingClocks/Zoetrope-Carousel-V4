	)
	(text "Dual Core ESP32-S3 240Mhz\n1.43\" AMOLED Circular 466×466 \n512KB SRAM and 384KB ROM\n16MB Flash and 8MB PSRAM\nQMI8658 6-axis IMU\nPCF85063 RTC\nMicroSD card reader\nTouch screen\nESP32-S3-Touch-AMOLED-1.43\n\nUART pins broken out underneath PCB\n\nUltra-low-profile USB-C cables\nrouted underneath the PCB to \npower/program each ESP32"
		(exclude_from_sim no)
		(at 236.474 66.548 0)
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.375)
			)
			(justify left bottom)
		)
		(uuid "5b7b791d-3884-428f-9531-33819fd15075")
	)
	(text "Each ESP32 Display board are mounted \ninto the PCB via connectors. There are\nholes for each board's USB-C connector\nThe USB-C Cables can either be ran to \na built-in powered USB hub to get its\npower, or power can be supplied via\nthe pins on the board. A diode is \nincluded on each board's input"
		(exclude_from_sim no)
		(at 135.89 45.72 0)
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.375)
			)
			(justify left bottom)
		)
		(uuid "6822d96b-8577-431c-b60a-fa188757d880")
	)
	(text "UART interfaces with \nmain STM32 MCU"
		(exclude_from_sim no)
		(at 136.144 169.164 0)
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.375)
			)
			(justify left bottom)
		)
		(uuid "76cc0bb5-aa78-48c9-9136-cb2011049440")
	)
