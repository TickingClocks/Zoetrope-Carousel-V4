	(text "Externally powered USB Hub\n\neach USB port can\nbe turned ON/OFF\n\ncut off AC power adapter and \ncrimp on JST connector to \npower from main PCB with +5V\n\ninside the unit cut the power \nwire to the USB cable leading \nto the PC programming interface. \nThis prevents the PC from trying \nto power the machine. It is\nalso additional protection for \nthe PC programming the machine \nin the case of a fault."
		(exclude_from_sim no)
		(at 243.586 108.966 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "84b75698-2fb6-4e03-b146-efd70b556f76")
	)
